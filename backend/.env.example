# ============================================================
# CivicPulse AI — FastAPI Backend Environment Variables
# Copy this file to .env for local development.
# On Railway / Render / Fly.io, set these in the dashboard.
# ============================================================

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Your Fireworks AI API key.
# Get one free at https://fireworks.ai → Dashboard → API Keys.
FIREWORKS_API_KEY=fw_your_api_key_here

# ---------------------------------------------------------------------------
# OPTIONAL (sensible defaults are provided in config.py)
# ---------------------------------------------------------------------------

# Gemma-4 multimodal model identifier on Fireworks AI.
MODEL_NAME=accounts/fireworks/models/gemma-4-e4b-multimodal

# Comma-separated list of allowed frontend origins (CORS).
# Add your Vercel URL here before deploying.
# Example: http://localhost:3000,https://civicpulse-ai.vercel.app
ALLOWED_ORIGINS=http://localhost:3000
